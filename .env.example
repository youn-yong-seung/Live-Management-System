# =========================================================================
# Live-Management-System .env.example
#
# 실제 사용 시 이 파일을 .env로 복사하고 빈 값들을 채워서 사용.
# 이 파일(.env.example)에는 시크릿 값을 절대 적지 않음 — 키 이름만 노출.
# =========================================================================

# ── Database (Supabase Postgres) ──────────────────────────────────────────
# Supabase 콘솔 → Project Settings → Database → Connection string (pooler)
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres

# ── Supabase Auth (서버용) ────────────────────────────────────────────────
# Supabase 콘솔 → Project Settings → API
SUPABASE_URL=https://aadwlmcukaacqmiyoptc.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Supabase Auth (Vite/브라우저용) ───────────────────────────────────────
# Vite는 VITE_ 접두사가 붙은 변수만 클라이언트 번들에 노출.
# service_role 키는 절대 VITE_ 접두사 붙이지 말 것 — 브라우저에 노출되면 DB 전권한 유출.
VITE_SUPABASE_URL=https://aadwlmcukaacqmiyoptc.supabase.co
VITE_SUPABASE_ANON_KEY=

# ── Admin (기존 비밀번호 인증 — 한동안 병행 운영) ──────────────────────────
ADMIN_INITIAL_PASSWORD=

# ── Cron ──────────────────────────────────────────────────────────────────
CRON_SECRET=

# ── YouTube Data API v3 (OAuth - 웹 애플리케이션) ─────────────────────────
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=
