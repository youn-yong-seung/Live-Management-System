{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "pnpm --filter @workspace/live-crm run build",
  "outputDirectory": "artifacts/live-crm/dist",
  "installCommand": "pnpm install",
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "artifacts/api-server/src/**,lib/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path(.*)", "destination": "/api" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "* * * * *"
    }
  ]
}
